<Window x:Class="RND_clothing_e_shop.ShopPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Obchod"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FF111111">

    <Window.Resources>

        <!-- Buttons Style -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="55"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Category buttons Style -->
        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#CC1F1F1F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- Background -->
        <Image Source="Images/background.png"
               Stretch="UniformToFill"
               Opacity="2.0"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

        <!-- Back Button -->
        <Button Content="←"
                Width="70"
                Height="70"
                FontSize="30"
                FontWeight="Bold"
                Background="#66000000"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="25"
                Cursor="Hand"
                Click="BackButton_Click"
                Panel.ZIndex="3">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="35">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Logout -->
        <Button Content="Odhlásiť sa"
                Width="150"
                Height="55"
                FontSize="18"
                FontWeight="Bold"
                Background="#66000000"
                Foreground="White"
                BorderThickness="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="25"
                Cursor="Hand"
                Click="LogoutButton_Click"
                Panel.ZIndex="3">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Main Layout -->
        <Grid Margin="40">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    Background="#CC1A1A1A"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,20,0">

                <StackPanel>

                    <TextBlock Text="Kategórie"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <Button Content="Všetko"
                            Style="{StaticResource CategoryButtonStyle}"
                            Click="AllCategory_Click"/>

                    <Button Content="Tričká"
                            Style="{StaticResource CategoryButtonStyle}"
                            Click="TrickaCategory_Click"/>

                    <Button Content="Mikiny"
                            Style="{StaticResource CategoryButtonStyle}"
                            Click="MikinyCategory_Click"/>

                    <Button Content="Nohavice"
                            Style="{StaticResource CategoryButtonStyle}"
                            Click="NohaviceCategory_Click"/>

                    <Button Content="Bundy"
                            Style="{StaticResource CategoryButtonStyle}"
                            Click="BundyCategory_Click"/>

                    <Button Content="Topánky"
                            Style="{StaticResource CategoryButtonStyle}"
                            Click="TopankyCategory_Click"/>

                    <Button Content="Doplnky"
                            Style="{StaticResource CategoryButtonStyle}"
                            Click="DoplnkyCategory_Click"/>

                    <Border Height="30"/>

                    <Button Content="Prejsť do košíka"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="White"
                            Foreground="Black"
                            Click="CartButton_Click"/>

                </StackPanel>
            </Border>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="1"
                    Background="#CC1A1A1A"
                    CornerRadius="20"
                    Padding="20">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Section -->
                    <StackPanel>

                        <TextBlock Text="Obchod"
                                   Foreground="White"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <!-- SEARCH BAR -->
                        <Border Width="320"
                                Height="45"
                                CornerRadius="22"
                                Background="#AA2A2A2A"
                                BorderBrush="#FF444444"
                                BorderThickness="1"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="🔍"
                                           FontSize="18"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="#DDFFFFFF"/>

                                <TextBox x:Name="SearchBox"
                                         Grid.Column="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Gray"
                                         FontSize="16"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="White"
                                         Text="Hľadať..."
                                         TextChanged="SearchBox_TextChanged"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"/>

                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Products -->
                    <ScrollViewer Grid.Row="1"
                                  Margin="0,20,0,0">

                        <WrapPanel x:Name="ProductsPanel"
                                   Margin="20"/>

                    </ScrollViewer>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>